---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../lib/site';

const posts = (await getCollection('blog', (entry) => !entry.data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${SITE.name} Blog`,
  description: 'Guides og artikler om elmarkedet og elpriser i Danmark.',
  url: new URL('/blog/', SITE.url).toString(),
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishDate.toISOString(),
    url: new URL(`/blog/${post.id}/`, SITE.url).toString(),
    author: { '@type': 'Organization', name: post.data.author },
  })),
};
---

<BaseLayout
  title="Blog — guides og artikler om elpriser"
  description="Læs vores guides om elmarkedet, spotpriser, grøn strøm og hvordan du finder den billigste elaftale."
  canonical="/blog/"
  jsonLd={jsonLd}
>
  <div class="blog-index">
    <div class="container-wide">
      <Breadcrumb items={[{ label: 'Forside', href: '/' }, { label: 'Blog' }]} />

      <header class="page-header">
        <h1>Blog</h1>
        <p>Guides og baggrund om elmarkedet — hjælp til at træffe de bedste valg.</p>
      </header>

      {
        posts.length === 0 ? (
          <p class="empty">Ingen artikler endnu.</p>
        ) : (
          <div class="article-grid">
            {posts.map((post) => (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}/`}
                publishDate={post.data.publishDate}
                readTime={post.data.readTime}
                tags={post.data.tags}
              />
            ))}
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index {
    padding-block: 2rem 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
    max-width: 640px;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .page-header p {
    font-size: 1.0625rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
    margin: 0;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .empty {
    padding: 3rem 1rem;
    text-align: center;
    color: var(--color-fg-muted);
  }
</style>
