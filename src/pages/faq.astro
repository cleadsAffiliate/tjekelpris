---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/common/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

const grouped = entries.reduce<Record<string, typeof entries>>((acc, entry) => {
  const category = entry.data.category;
  if (!acc[category]) acc[category] = [];
  acc[category].push(entry);
  return acc;
}, {});

const categories = Object.keys(grouped);

const renderedEntries = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
const contentMap = new Map(renderedEntries.map((r) => [r.entry.id, r.Content]));

async function plainText(entry: (typeof entries)[number]): Promise<string> {
  return entry.body?.replace(/\s+/g, ' ').trim() ?? '';
}

const jsonLdEntities = await Promise.all(
  entries.map(async (entry) => ({
    '@type': 'Question',
    name: entry.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: await plainText(entry),
    },
  })),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: jsonLdEntities,
};
---

<BaseLayout
  title="FAQ — ofte stillede spørgsmål"
  description="Svar på de mest almindelige spørgsmål om elpriser, skift af elselskab, variabel vs fast pris, grøn strøm og meget mere."
  canonical="/faq/"
  jsonLd={jsonLd}
>
  <div class="faq-page">
    <div class="container-narrow">
      <Breadcrumb items={[{ label: 'Forside', href: '/' }, { label: 'FAQ' }]} />

      <header class="page-header">
        <h1>Ofte stillede spørgsmål</h1>
        <p>Hurtige svar om elpriser, skift af selskab og hvordan elmarkedet fungerer.</p>
      </header>

      {
        categories.map((category) => (
          <section class="faq-section" aria-labelledby={`cat-${category.replace(/\s+/g, '-').toLowerCase()}`}>
            <h2 id={`cat-${category.replace(/\s+/g, '-').toLowerCase()}`}>{category}</h2>
            <dl class="faq-list">
              {grouped[category].map((entry) => {
                const Content = contentMap.get(entry.id)!;
                return (
                  <div class="faq-item">
                    <dt>{entry.data.question}</dt>
                    <dd>
                      <Content />
                    </dd>
                  </div>
                );
              })}
            </dl>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .faq-page {
    padding-block: 2rem 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .page-header p {
    font-size: 1.0625rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
    margin: 0;
  }

  .faq-section {
    margin-bottom: 3rem;
  }

  .faq-section h2 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-subtle);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
  }

  .faq-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item dt {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    margin: 0 0 0.75rem;
    line-height: 1.35;
  }

  .faq-item dd {
    margin: 0;
  }

  .faq-item dd :global(p) {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
  }

  .faq-item dd :global(p:last-child) {
    margin-bottom: 0;
  }

  .faq-item dd :global(ul),
  .faq-item dd :global(ol) {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
    padding-left: 1.25rem;
  }

  .faq-item dd :global(li) {
    margin-bottom: 0.375rem;
  }

  .faq-item dd :global(a) {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .faq-item dd :global(strong) {
    color: var(--color-fg);
    font-weight: 600;
  }
</style>
