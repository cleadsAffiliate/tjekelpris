---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/common/Breadcrumb.astro';
import PriceCalculator from '../../components/comparison/PriceCalculator.astro';
import PriceTable from '../../components/comparison/PriceTable.astro';
import FilterBar from '../../components/comparison/FilterBar.astro';
import { fetchProducts } from '../../lib/supabase';
import { STANDARD_ANNUAL_KWH } from '../../lib/types';

const products = await fetchProducts();

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Sammenligning af elpriser',
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `${p.provider.name} — ${p.product_name}`,
      brand: { '@type': 'Brand', name: p.provider.name },
      offers: {
        '@type': 'Offer',
        price: p.estimated_monthly,
        priceCurrency: 'DKK',
        url: p.provider.website_url,
      },
    },
  })),
};
---

<BaseLayout
  title="Sammenlign elpriser fra alle elselskaber"
  description="Sammenlign priser fra danske elselskaber på ét sted. Filtrér efter binding, afregning, grøn strøm og find den billigste elaftale for dit forbrug."
  canonical="/elpriser/"
  jsonLd={itemListJsonLd}
>
  <div class="elpriser-page">
    <div class="container-wide">
      <Breadcrumb items={[{ label: 'Forside', href: '/' }, { label: 'Elpriser' }]} />

      <header class="page-header">
        <h1>Sammenlign elpriser</h1>
        <p>
          {products.length} aftaler fra {new Set(products.map((p) => p.provider.name)).size} elselskaber.
          Estimater bygger på et årligt forbrug du selv justerer.
        </p>
      </header>

      <section aria-labelledby="calc-heading" class="calc-section">
        <h2 id="calc-heading" class="sr-only">Prisberegner</h2>
        <PriceCalculator defaultKwh={STANDARD_ANNUAL_KWH} />
      </section>

      <section aria-labelledby="table-heading">
        <h2 id="table-heading" class="sr-only">Resultater</h2>
        <FilterBar />
        <PriceTable products={products} annualKwh={STANDARD_ANNUAL_KWH} />
      </section>

      <aside class="disclaimer">
        <h2>Sådan beregner vi priserne</h2>
        <p>
          Estimatet pr. måned beregnes ud fra <strong>spotpris + selskabets påslag</strong>, plus
          <strong>abonnementet</strong>, multipliceret med 1/12 af dit årlige forbrug. Transport og
          afgifter (ens for alle) er ikke inkluderet — de betales særskilt til dit netselskab og staten.
        </p>
        <p>
          Spotprisen der bruges som baseline er et gennemsnit for de seneste 30 dage. Priser er
          vejledende og bør altid bekræftes hos det pågældende selskab inden bestilling.
        </p>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .elpriser-page {
    padding-block: 2rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
    max-width: 720px;
  }

  .page-header h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .page-header p {
    font-size: 1.0625rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
    margin: 0;
  }

  .calc-section {
    margin-bottom: 2rem;
  }

  .disclaimer {
    margin-top: 3rem;
    padding: 1.75rem;
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    max-width: 820px;
  }

  .disclaimer h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    letter-spacing: -0.015em;
  }

  .disclaimer p {
    margin: 0 0 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .disclaimer p:last-child {
    margin-bottom: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
