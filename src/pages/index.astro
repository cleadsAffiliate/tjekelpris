		</main>
		<footer></footer>
		<script>
			(() => {
				const forbrug = document.getElementById('forbrug');
				if (!forbrug) return;

				const formatter = new Intl.NumberFormat('da-DK');

				function format(value) {
					const raw = value.replace(/\D/g, '');
					if (raw === '') return '';
					return formatter.format(parseInt(raw, 10));
				}

				forbrug.addEventListener('input', (event) => {
					const target = event.target;
					const before = target.value;
					const cursor = target.selectionStart ?? before.length;
					const digitsBeforeCursor = before.slice(0, cursor).replace(/\D/g, '').length;

					const formatted = format(before);
					target.value = formatted;

					let newCursor = 0;
					let seen = 0;
					for (let i = 0; i < formatted.length && seen < digitsBeforeCursor; i++) {
						if (/\d/.test(formatted[i])) seen++;
						newCursor = i + 1;
					}
					target.setSelectionRange(newCursor, newCursor);
				});

				forbrug.addEventListener('blur', () => {
					forbrug.value = format(forbrug.value);
				});
			})();
		</script>
