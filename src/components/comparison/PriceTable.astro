---
import ProviderLogo from '../common/ProviderLogo.astro';
import TrustpilotStars from '../common/TrustpilotStars.astro';
import { formatInteger, formatPrice } from '../../lib/format';
import { SETTLEMENT_LABELS } from '../../lib/types';
import type { ProductWithProvider } from '../../lib/types';

interface Props {
  products: ProductWithProvider[];
  annualKwh?: number;
}

const { products, annualKwh = 4000 } = Astro.props;
---

<div class="price-table-wrapper" data-price-table>
  <table class="price-table" aria-describedby="price-table-caption">
    <caption id="price-table-caption" class="sr-only">
      Sammenligning af elselskaber. Priser baseret på et årligt forbrug på {formatInteger(annualKwh)} kWh.
    </caption>
    <thead>
      <tr>
        <th scope="col" class="col-rank">#</th>
        <th scope="col" class="col-provider">Selskab & produkt</th>
        <th scope="col" class="col-num">Abon.<br /><span class="th-unit">kr/md.</span></th>
        <th scope="col" class="col-num">Pris<br /><span class="th-unit">kr/kWh</span></th>
        <th scope="col" class="col-num">Binding</th>
        <th scope="col" class="col-type">Afregning</th>
        <th scope="col" class="col-num col-primary">Est. pr. md.<br /><span class="th-unit">kr</span></th>
        <th scope="col" class="col-action"><span class="sr-only">Handling</span></th>
      </tr>
    </thead>
    <tbody>
      {
        products.map((p, i) => (
          <tr data-row data-settlement={p.settlement_type} data-price-type={p.price_type} data-green={String(p.green_energy)} data-binding={String(p.binding_months)} data-monthly={p.estimated_monthly} data-kwh-price={p.estimated_kwh_price} data-subscription={p.subscription_fee} data-spot-premium={p.spot_premium}>
            <td class="col-rank">
              <span class="rank-num" data-rank>{i + 1}</span>
            </td>
            <td class="col-provider">
              <div class="provider-cell">
                <ProviderLogo name={p.provider.name} size={32} />
                <div class="provider-meta">
                  <span class="provider-name">{p.provider.name}</span>
                  <span class="product-name">{p.product_name}</span>
                  <span class="tp-row">
                    <TrustpilotStars score={p.provider.trustpilot_score} />
                  </span>
                </div>
              </div>
            </td>
            <td class="col-num tabular-nums">{formatInteger(p.subscription_fee)}</td>
            <td class="col-num tabular-nums" data-kwh-display>{formatPrice(p.estimated_kwh_price)}</td>
            <td class="col-num">
              {p.binding_months === 0 ? <span class="tag tag-success">Ingen</span> : `${p.binding_months} mdr.`}
            </td>
            <td class="col-type">{SETTLEMENT_LABELS[p.settlement_type]}</td>
            <td class="col-num col-primary tabular-nums" data-monthly-display>
              {formatInteger(p.estimated_monthly)}
            </td>
            <td class="col-action">
              <a
                href={p.provider.website_url}
                class="btn-link"
                rel="sponsored nofollow noopener"
                target="_blank"
              >
                Se tilbud
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M7 17L17 7M17 7H8M17 7v9"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
  <p class="table-empty" hidden data-empty>Ingen produkter matcher dine filtre.</p>
</div>

<style>
  .price-table-wrapper {
    width: 100%;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg);
  }

  .price-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    min-width: 860px;
  }

  .price-table thead {
    background-color: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .price-table th {
    padding: 0.875rem 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    letter-spacing: 0.01em;
    vertical-align: bottom;
  }

  .th-unit {
    display: block;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-fg-subtle);
    margin-top: 0.125rem;
  }

  .col-num {
    text-align: right;
    white-space: nowrap;
  }

  .col-primary {
    color: var(--color-fg);
  }

  .col-rank {
    width: 2.5rem;
    text-align: center;
    color: var(--color-fg-subtle);
    font-weight: 500;
  }

  .col-action {
    width: 1%;
  }

  .price-table tbody tr {
    border-bottom: 1px solid var(--color-border);
  }

  .price-table tbody tr:last-child {
    border-bottom: none;
  }

  .price-table tbody tr[hidden] {
    display: none;
  }

  .price-table td {
    padding: 0.875rem 0.75rem;
    vertical-align: middle;
  }

  .rank-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background-color: var(--color-bg-muted);
    color: var(--color-fg-muted);
    border-radius: 50%;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .provider-cell {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .provider-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    min-width: 0;
  }

  .provider-name {
    font-weight: 600;
    color: var(--color-fg);
    font-size: 0.9375rem;
    line-height: 1.2;
  }

  .product-name {
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    line-height: 1.2;
  }

  .tp-row {
    margin-top: 0.125rem;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background-color: var(--color-bg-muted);
    color: var(--color-fg);
    font-weight: 500;
    font-size: 0.875rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    border: 1px solid var(--color-border-strong);
    transition: background-color 0.15s ease, border-color 0.15s ease;
    white-space: nowrap;
  }

  .btn-link:hover {
    background-color: var(--color-brand-subtle);
    border-color: var(--color-brand);
    color: var(--color-brand);
  }

  .table-empty {
    padding: 3rem 1.5rem;
    text-align: center;
    color: var(--color-fg-muted);
    margin: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
