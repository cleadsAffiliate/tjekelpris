---
import ProviderLogo from '../common/ProviderLogo.astro';
import TrustpilotStars from '../common/TrustpilotStars.astro';
import { formatInteger, formatPrice } from '../../lib/format';
import { SETTLEMENT_LABELS } from '../../lib/types';
import type { ProductWithProvider } from '../../lib/types';

interface Props {
  product: ProductWithProvider;
  rank?: number;
  highlight?: boolean;
}

const { product, rank, highlight = false } = Astro.props;
const bindingLabel = product.binding_months === 0 ? 'Ingen binding' : `${product.binding_months} mdr.`;
const settlementLabel = SETTLEMENT_LABELS[product.settlement_type];
---

<article class={`provider-card${highlight ? ' is-highlight' : ''}`}>
  {
    rank !== undefined && (
      <span class="rank" aria-label={`Placering ${rank}`}>
        #{rank}
      </span>
    )
  }

  <header class="card-header">
    <ProviderLogo name={product.provider.name} size={44} />
    <div class="provider-info">
      <h3 class="provider-name">{product.provider.name}</h3>
      <p class="product-name">{product.product_name}</p>
      <TrustpilotStars score={product.provider.trustpilot_score} />
    </div>
  </header>

  <dl class="metrics">
    <div class="metric metric-primary">
      <dt>Est. månedlig</dt>
      <dd>
        <span class="value tabular-nums">{formatInteger(product.estimated_monthly)}</span>
        <span class="unit">kr/md.</span>
      </dd>
    </div>
    <div class="metric">
      <dt>Pris pr. kWh</dt>
      <dd class="tabular-nums">{formatPrice(product.estimated_kwh_price)} kr</dd>
    </div>
    <div class="metric">
      <dt>Abonnement</dt>
      <dd class="tabular-nums">{formatInteger(product.subscription_fee)} kr/md.</dd>
    </div>
    <div class="metric">
      <dt>Binding</dt>
      <dd>{bindingLabel}</dd>
    </div>
    <div class="metric">
      <dt>Afregning</dt>
      <dd>{settlementLabel}</dd>
    </div>
    <div class="metric">
      <dt>Grøn strøm</dt>
      <dd>{product.green_energy ? 'Ja' : 'Nej'}</dd>
    </div>
  </dl>

  {
    product.features.length > 0 && (
      <ul class="features">
        {product.features.map((feature) => (
          <li class="tag">{feature}</li>
        ))}
      </ul>
    )
  }

  <div class="actions">
    <a
      href={product.provider.website_url}
      class="btn btn-primary"
      rel="sponsored nofollow noopener"
      target="_blank"
    >
      Se tilbud
    </a>
    <a href={product.provider.trustpilot_url} class="link-muted" rel="nofollow noopener" target="_blank">
      Trustpilot
    </a>
  </div>
</article>

<style>
  .provider-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .provider-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }

  .provider-card.is-highlight {
    border-color: color-mix(in srgb, var(--color-brand) 40%, transparent);
    background-color: var(--color-bg);
  }

  .rank {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-fg-subtle);
    background-color: var(--color-bg-muted);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  .card-header {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .provider-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .provider-name {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-fg);
  }

  .product-name {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-fg-muted);
    line-height: 1.3;
  }

  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem 1rem;
    margin: 0;
    padding: 0;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric dt {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-fg-subtle);
    letter-spacing: 0.02em;
  }

  .metric dd {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-fg);
  }

  .metric-primary {
    grid-column: 1 / -1;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid var(--color-border);
  }

  .metric-primary dt {
    font-size: 0.8125rem;
  }

  .metric-primary .value {
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-fg);
  }

  .metric-primary .unit {
    margin-left: 0.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-fg-muted);
  }

  .features {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0;
    margin: 0;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .actions .btn {
    flex: 1;
  }

  .link-muted {
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    text-decoration: none;
  }

  .link-muted:hover {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
