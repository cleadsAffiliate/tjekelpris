---
interface Props {
  score: number;
  showScore?: boolean;
  size?: 'sm' | 'md';
}

const { score, showScore = true, size = 'sm' } = Astro.props;
const clamped = Math.max(0, Math.min(5, score));
const fillPercent = (clamped / 5) * 100;
const starSize = size === 'md' ? 18 : 14;
---

<span class="trustpilot" aria-label={`Trustpilot score ${clamped.toFixed(1)} ud af 5`}>
  <span
    class="stars"
    style={`--fill:${fillPercent}%; --star:${starSize}px;`}
    role="img"
    aria-hidden="true"
  >
    <svg width="0" height="0" style="position:absolute">
      <defs>
        <symbol id="tp-star" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </symbol>
      </defs>
    </svg>
    <span class="track">
      {Array.from({ length: 5 }).map(() => <svg class="star-bg"><use href="#tp-star" /></svg>)}
    </span>
    <span class="fill">
      {Array.from({ length: 5 }).map(() => <svg class="star-fg"><use href="#tp-star" /></svg>)}
    </span>
  </span>
  {showScore && <span class="score tabular-nums">{clamped.toFixed(1)}</span>}
</span>

<style>
  .trustpilot {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    line-height: 1;
  }

  .stars {
    position: relative;
    display: inline-block;
    width: calc(var(--star) * 5 + 8px);
    height: var(--star);
  }

  .track,
  .fill {
    position: absolute;
    inset: 0;
    display: inline-flex;
    gap: 2px;
  }

  .track svg,
  .fill svg {
    width: var(--star);
    height: var(--star);
    flex-shrink: 0;
  }

  .track {
    color: var(--color-border-strong);
  }

  .fill {
    color: #00b67a;
    overflow: hidden;
    width: var(--fill);
  }

  .star-bg,
  .star-fg {
    fill: currentColor;
  }

  .score {
    font-weight: 500;
    color: var(--color-fg);
  }
</style>
