---
import { formatDateDa } from '../../lib/format';

interface Props {
  title: string;
  description: string;
  href: string;
  publishDate: Date;
  readTime?: number;
  tags?: string[];
}

const { title, description, href, publishDate, readTime, tags = [] } = Astro.props;
---

<article class="article-card">
  <a href={href} class="card-link">
    <div class="meta-row">
      <time datetime={publishDate.toISOString()}>{formatDateDa(publishDate)}</time>
      {readTime && <span>{readTime} min læsning</span>}
    </div>
    <h3 class="article-title">{title}</h3>
    <p class="article-description">{description}</p>
    {
      tags.length > 0 && (
        <ul class="article-tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <span class="read-more">
      Læs artikel
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M5 12h14M13 6l6 6-6 6"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
  </a>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .article-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.5rem;
    color: var(--color-fg);
    text-decoration: none;
    height: 100%;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-fg-subtle);
  }

  .meta-row time {
    font-variant-numeric: tabular-nums;
  }

  .meta-row time + span::before {
    content: '·';
    margin-right: 0.75rem;
  }

  .article-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--color-fg);
  }

  .article-description {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
  }

  .article-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin: 0.25rem 0 0;
    padding: 0;
  }

  .read-more {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand);
    padding-top: 0.5rem;
  }

  .article-card:hover .read-more svg {
    transform: translateX(2px);
  }

  .read-more svg {
    transition: transform 0.15s ease;
  }
</style>
